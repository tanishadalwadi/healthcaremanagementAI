# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# Frontend origins allowed to call this API (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Supabase PostgreSQL
# Pooled connection (use for the application runtime)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (use for Prisma migrations)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Auth (required in production — dev server has a fallback if unset)
JWT_SECRET="change-me-in-production"

# Google Gemini (optional — AI falls back to rule-based summaries without a key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
