generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  NURSE
  DOCTOR
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PatientStatus {
  ACTIVE
  DISCHARGED
  WAITING
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkflowEventStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum WorkflowEventType {
  ADMISSION
  TRIAGE
  LAB_ORDERED
  LAB_COMPLETED
  IMAGING_ORDERED
  IMAGING_COMPLETED
  CONSULTATION
  TREATMENT
  MEDICATION
  INSURANCE_REVIEW
  DISCHARGE_PLANNING
  DISCHARGE_READY
  DISCHARGE
  BLOCKED
}

enum EventType {
  PATIENT_ADMITTED
  LAB_COMPLETED
  MRI_COMPLETED
  NEW_DOCTOR_ORDER
  MEDICATION_ADMINISTERED
  INSURANCE_DELAY
  DISCHARGE_READY
  SHIFT_STARTED
  SHIFT_ENDED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum ConsultationStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
}

enum AmbulanceStatus {
  AVAILABLE
  DISPATCHED
}

enum DischargeConditionStatus {
  COMPLETE
  INCOMPLETE
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  passwordHash String?   @map("password_hash")
  role         UserRole
  departmentId String?   @map("department_id") @db.Uuid
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  department               Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedPatientsAsNurse  Patient[]   @relation("AssignedNurse")
  assignedPatientsAsDoctor Patient[]   @relation("AssignedDoctor")
  consultationsAsDoctor  Consultation[] @relation("ConsultationDoctor")
  workflowEventsCreated  WorkflowEvent[] @relation("WorkflowEventCreator")
  tasks                    Task[]
  vitalSignsRecorded       VitalSign[] @relation("VitalSignRecorder")
  notifications            Notification[]

  @@index([role])
  @@index([departmentId])
  @@index([active])
  @@map("users")
}

model Department {
  id        String           @id @default(uuid()) @db.Uuid
  name      String           @unique
  status    DepartmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  patients Patient[]
  users    User[]
  consultations Consultation[]
  beds     Bed[]

  @@index([status])
  @@index([deletedAt])
  @@map("departments")
}

model Patient {
  id                   String        @id @default(uuid()) @db.Uuid
  patientNumber        String        @unique @map("patient_number")
  firstName            String        @map("first_name")
  lastName             String        @map("last_name")
  age                  Int
  gender               Gender
  room                 String?
  diagnosis            String?
  status               PatientStatus @default(ACTIVE)
  priority             Priority      @default(MEDIUM)
  departmentId         String        @map("department_id") @db.Uuid
  assignedNurseId      String?       @map("assigned_nurse_id") @db.Uuid
  assignedDoctorId     String?       @map("assigned_doctor_id") @db.Uuid
  dischargeRequestedAt DateTime?     @map("discharge_requested_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  deletedAt            DateTime?     @map("deleted_at")

  department     Department     @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  assignedNurse  User?          @relation("AssignedNurse", fields: [assignedNurseId], references: [id], onDelete: SetNull)
  assignedDoctor User?          @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id], onDelete: SetNull)
  workflowEvents WorkflowEvent[]
  events         PatientEvent[]
  tasks          Task[]
  consultations  Consultation[]
  vitalSigns     VitalSign[]
  notifications  Notification[]
  dischargeConditions DischargeCondition[]
  bed            Bed?

  @@index([departmentId])
  @@index([assignedNurseId])
  @@index([assignedDoctorId])
  @@index([status])
  @@index([priority])
  @@index([patientNumber])
  @@index([deletedAt])
  @@map("patients")
}

model WorkflowEvent {
  id          String              @id @default(uuid()) @db.Uuid
  patientId   String              @map("patient_id") @db.Uuid
  title       String
  description String?
  eventType   WorkflowEventType   @map("event_type")
  status      WorkflowEventStatus @default(PENDING)
  sequence    Int
  createdBy   String?             @map("created_by") @db.Uuid
  occurredAt  DateTime            @default(now()) @map("occurred_at")
  startedAt   DateTime?           @map("started_at")
  completedAt DateTime?           @map("completed_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  creator User?   @relation("WorkflowEventCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([patientId, sequence])
  @@index([patientId])
  @@index([status])
  @@index([eventType])
  @@index([occurredAt])
  @@map("workflow_events")
}

model PatientEvent {
  id          String    @id @default(uuid()) @db.Uuid
  patientId   String    @map("patient_id") @db.Uuid
  eventType   EventType @map("event_type")
  description String
  createdBy   String    @map("created_by")
  timestamp   DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([eventType])
  @@index([timestamp])
  @@map("patient_events")
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  patientId   String     @map("patient_id") @db.Uuid
  title       String
  description String?
  assignedTo  String     @map("assigned_to") @db.Uuid
  status      TaskStatus @default(TODO)
  dueAt       DateTime?  @map("due_at")
  completedAt DateTime?  @map("completed_at")

  patient  Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  assignee User    @relation(fields: [assignedTo], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([assignedTo])
  @@index([status])
  @@index([dueAt])
  @@map("tasks")
}

model Consultation {
  id           String             @id @default(uuid()) @db.Uuid
  patientId    String             @map("patient_id") @db.Uuid
  doctorId     String             @map("doctor_id") @db.Uuid
  departmentId String             @map("department_id") @db.Uuid
  reason       String
  notes        String?
  status       ConsultationStatus @default(SCHEDULED)
  scheduledAt  DateTime?          @map("scheduled_at")
  startedAt    DateTime?          @map("started_at")
  completedAt  DateTime?          @map("completed_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  patient    Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor     User       @relation("ConsultationDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([doctorId])
  @@index([departmentId])
  @@index([status])
  @@index([scheduledAt])
  @@map("consultations")
}

model VitalSign {
  id           String   @id @default(uuid()) @db.Uuid
  patientId    String   @map("patient_id") @db.Uuid
  recordedById String?  @map("recorded_by_id") @db.Uuid
  bloodPressure String  @map("blood_pressure")
  pulse        Int
  temperature  Float
  respRate     Int      @map("resp_rate")
  o2Saturation Int      @map("o2_saturation")
  recordedAt   DateTime @default(now()) @map("recorded_at")

  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedBy User?   @relation("VitalSignRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([recordedAt])
  @@map("vital_signs")
}

model Bed {
  id           String    @id @default(uuid()) @db.Uuid
  roomLabel    String    @unique @map("room_label")
  departmentId String    @map("department_id") @db.Uuid
  status       BedStatus @default(AVAILABLE)
  patientId    String?   @unique @map("patient_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  patient    Patient?   @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([departmentId])
  @@index([status])
  @@map("beds")
}

model Ambulance {
  id        String           @id @default(uuid()) @db.Uuid
  unitLabel String           @unique @map("unit_label")
  status    AmbulanceStatus  @default(AVAILABLE)
  label     String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@map("ambulances")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  patientId String   @map("patient_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  summary   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

model DischargeCondition {
  id                String                   @id @default(uuid()) @db.Uuid
  patientId         String                   @map("patient_id") @db.Uuid
  condition         String
  status            DischargeConditionStatus @default(INCOMPLETE)
  owningDepartment  String                   @map("owning_department")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, condition])
  @@index([patientId])
  @@index([status])
  @@map("discharge_conditions")
}
